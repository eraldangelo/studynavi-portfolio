{
  "name": "nextn",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "next:dev": "next dev -p 9002 --hostname 0.0.0.0",
    "build": "cross-env NODE_ENV=production next build",
    "export": "next export",
    "start": "node scripts/start.js",
    "lint": "eslint --ext .ts,.tsx,.js,.jsx .",
    "typecheck": "tsc --noEmit",
    "test:regression": "tsx scripts/regression-tests.ts && tsx scripts/regression-payment-types.ts && tsx scripts/regression-golden-values.ts",
    "test:security": "tsx scripts/security-tests.ts && tsx scripts/security-tests-network.ts && tsx scripts/security-tests-hardening.ts && tsx scripts/security-tests-hardening-network.ts && tsx scripts/contract-tests-pathfinder.ts",
    "test:contract:pathfinder": "tsx scripts/contract-tests-pathfinder.ts",
    "check:java": "node scripts/check-java.js",
    "test:rules": "npm run check:java && npx firebase-tools@15.5.1 emulators:exec --project demo-studynavi --only firestore,storage \"tsx tests/rules/semantic-rules.test.ts\"",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test e2e/smoke.spec.ts --reporter=line",
    "test:e2e:regression": "playwright test e2e/regression.spec.ts --reporter=line",
    "prepush:local": "npm run typecheck && npm run lint && npm run check:secrets && npm run check:claims-cutover && npm run test:contract:pathfinder && npm run check:file-lengths",
    "check:modals": "node scripts/validate-modals.js",
    "check:file-lengths": "node scripts/check-file-lengths.js",
    "check:secrets": "node scripts/check-secrets.js",
    "check:unused-exports": "node scripts/check-unused-exports.js",
    "postdeploy:check": "node scripts/postdeploy-check.js",
    "ops:check:drift": "node scripts/check-ops-drift.js",
    "ops:check:drift:repo": "cross-env OPS_DRIFT_MODE=repo node scripts/check-ops-drift.js",
    "ops:check:drift:cloud": "cross-env OPS_DRIFT_MODE=cloud OPS_DRIFT_REQUIRE_CLOUD=true node scripts/check-ops-drift.js",
    "check:claims-cutover": "node scripts/check-claims-cutover.js",
    "check:claims-cutover:cloud": "cross-env CLAIMS_CHECK_MODE=cloud CLAIMS_CHECK_REQUIRE_CLOUD=true node scripts/check-claims-cutover.js",
    "check:recovery-drill": "node scripts/release/validate-recovery-drill.js",
    "doctor": "node scripts/doctor.js",
    "backup:fees": "node scripts/backup-fees.js",
    "restore:fees": "node scripts/release/restore-fees.js",
    "changelog:generate": "node scripts/generate-changelog.js",
    "hooks:setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-githooks.ps1",
    "verify": "npm run typecheck && npm run lint && npm run check:unused-exports && npm run check:secrets && npm run test:regression && npm run test:security && npm run check:claims-cutover && npm run check:recovery-drill && npm run build && npm run check:modals && npm run check:file-lengths",
    "verify:smoke": "npm run verify && npm run test:e2e:smoke",
    "ci:local": "npm run verify:smoke && npm run test:e2e:regression"
  },
  "dependencies": {
    "@hookform/resolvers": "^4.1.3",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-menubar": "^1.1.6",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.0",
    "@radix-ui/react-scroll-area": "^1.1.0",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.1",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-spring/web": "^9.7.4",
    "axios": "^1.7.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "date-fns": "^3.6.0",
    "embla-carousel-react": "^8.1.5",
    "firebase": "^12.8.0",
    "firebase-admin": "^12.1.1",
    "geist": "^1.3.0",
    "html2canvas": "^1.4.1",
    "input-otp": "^1.2.5",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.395.0",
    "next": "16.1.7",
    "next-themes": "^0.3.0",
    "react": "^18",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18",
    "react-hook-form": "^7",
    "react-resizable-panels": "^2.0.19",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.3.0",
    "zod": "^3.25.76",
    "zod-validation-error": "^1.5.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@playwright/test": "^1.52.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.1.7",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "ts-prune": "^0.10.3",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "overrides": {
    "node-forge": "^1.4.0",
    "fast-xml-parser": "^5.5.10",
    "dompurify": "^3.3.3"
  }
}
