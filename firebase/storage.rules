rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && request.auth.token.keys().hasAny(['admin'])
        && request.auth.token.admin == true;
    }

    function isLegacyStaffCompat() {
      return isSignedIn()
        && request.auth.token.keys().hasAny(['legacy_staff_email_fallback'])
        && request.auth.token.legacy_staff_email_fallback == true
        && request.auth.token.keys().hasAny(['email'])
        && request.auth.token.email is string
        && request.auth.token.keys().hasAny(['email_verified'])
        && request.auth.token.email_verified == true
        && request.auth.token.email.matches('(?i).+@example\\.com$');
    }

    function isStaff() {
      return isAdmin()
        || (
          isSignedIn()
          && (
            (
              request.auth.token.keys().hasAny(['staff'])
              && request.auth.token.staff == true
            )
            || (
              request.auth.token.keys().hasAny(['support'])
              && request.auth.token.support == true
            )
          )
        )
        || isLegacyStaffCompat();
    }

    // Bug report screenshots are user-scoped and staff-readable.
    match /reports/{userId}/{allPaths=**} {
      allow read: if isStaff() || (isSignedIn() && request.auth.uid == userId);
      allow write: if isSignedIn()
        && (request.auth.uid == userId || isStaff())
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Deny other writes by default
    match /{allPaths=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}


