NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
# Required when Firebase App Check is enforced for Authentication.
NEXT_PUBLIC_FIREBASE_APPCHECK_SITE_KEY=
# Optional local debug token only (never set in production).
NEXT_PUBLIC_FIREBASE_APPCHECK_DEBUG_TOKEN=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Optional: expected Turnstile action label, defaults to login.
TURNSTILE_EXPECTED_ACTION=login
# Optional: comma-separated hostnames for Turnstile hostname validation.
TURNSTILE_ALLOWED_HOSTNAMES=localhost,127.0.0.1
# Optional: server-side staff domain used for support/admin report visibility.
STUDYNAVI_STAFF_EMAIL_DOMAIN=example.com
# Optional: expose staff-domain override to client read-only staff visibility checks.
NEXT_PUBLIC_STUDYNAVI_STAFF_EMAIL_DOMAIN=example.com
# Optional: claims cutover mode: bridge (default) or strict.
STUDYNAVI_CLAIMS_CUTOVER_MODE=bridge
NEXT_PUBLIC_STUDYNAVI_CLAIMS_CUTOVER_MODE=bridge
# Optional: temporary compatibility bridge for legacy staff-domain access.
# Keep false unless an explicit migration exception is approved.
NEXT_PUBLIC_STUDYNAVI_ENABLE_LEGACY_STAFF_COMPAT_BRIDGE=false
STUDYNAVI_ENABLE_LEGACY_STAFF_COMPAT_BRIDGE=false
# Optional: trusted proxy/IP extraction mode for server abuse controls.
TRUST_PROXY_MODE=auto
# Optional: comma-separated runtime alert source prefixes (default pdf.).
RUNTIME_ALERT_ALLOWED_SOURCES=pdf.
# Optional: require explicit staff/admin claim for chat-corrections mutations.
STUDYNAVI_REQUIRE_STAFF_CLAIM_FOR_CORRECTIONS=true
# Required in production: HMAC secret used for server-trusted session cookies.
STUDYNAVI_SESSION_SECRET=
# Optional: server-trusted session TTL in seconds (default 43200, min 300, max 604800).
STUDYNAVI_SESSION_TTL_SECONDS=43200
# Optional: require valid turnstile proof before minting server session cookie.
STUDYNAVI_SESSION_REQUIRE_TURNSTILE_PROOF=true
# Optional: set true to emit stricter CSP as report-only during rollout.
CSP_ENABLE_STRICT_REPORT_ONLY=false
# Optional: set true to enforce stricter CSP (turn this on only after report-only triage is clean).
CSP_ENABLE_STRICT_ENFORCE=false
# Server-only keys used by AI/protected APIs.
OPENAI_API_KEY=
FIREBASE_SERVICE_ACCOUNT=
GOOGLE_APPLICATION_CREDENTIALS=

